# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# GCP Cloud Storage
GCS_BUCKET_NAME=rlystate-v2-assets
GCP_PROJECT_ID=your-gcp-project-id
# Local only. Point this at a service account key JSON downloaded from GCP Console.
# In Cloud Run, omit this variable entirely. The attached service account is used automatically.
GCP_CREDENTIALS_PATH=./credentials/rlystate-sa.json

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=8080
NODE_ENV=development
JWT_SECRET=changeme
FRONTEND_URL=http://localhost:3000
